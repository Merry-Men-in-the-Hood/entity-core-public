# =====================================================
# Entity v0 - Environment Variables
# =====================================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to git (already in .gitignore).
# =====================================================

# --- Venice (uncensored, x402 native) ---
# Get from: https://venice.ai → wallet-based, no signup needed
VENICE_API_URL=https://api.venice.ai/api/v1
VENICE_WALLET_ADDRESS=0xYOUR_VENICE_PAYMENT_WALLET
VENICE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_FOR_X402_SIGNING

# --- X (Twitter) API v2 ---
# Get from: https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAA...
X_API_KEY=YOUR_API_KEY
X_API_SECRET=YOUR_API_SECRET
X_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
X_ACCESS_SECRET=YOUR_ACCESS_SECRET

# --- Telegram Bot ---
# Get from: @BotFather on Telegram
# Bot must be added to @OpenGoodEntity channel as Admin with Post Messages perm
TELEGRAM_BOT_TOKEN=123456789:ABCDEF-ghijklmnopqrstuvwxyz
TELEGRAM_CHANNEL_ID=@OpenGoodEntity

# Treasury (donation address; valid on all EVM chains: Ethereum, Base, Robinhood)
# Holds donations and pays operating costs.
TREASURY_ADDRESS=0x33EeB0A8d06bED91B4abf96DED14B96Ee093d66d

# --- Guardian Safe (kill-switch, Base only) ---
# DEDICATED multisig used ONLY to halt Entity.
# Threshold: 2-of-3 (two founders coordinate to trigger halt).
# Mechanism: Entity polls this Safe's nonce(). Any outgoing tx = HALT.
# Do NOT use this Safe for funds, donations, or anything else.
GUARDIAN_SAFE_ADDRESS=0x96658e40542bdA7eD64e2e958399C514827FD59D

# --- Base RPC (used for Guardian Safe polling) ---
# Default public RPC. Replace with Alchemy/QuickNode for higher reliability.
BASE_RPC_URL=https://mainnet.base.org
KILLSWITCH_POLL_INTERVAL=60

# --- Robinhood RPC (chain id 4663, EVM L2 on Arbitrum) ---
# Entity operates across Ethereum, Base, and Robinhood.
# Public RPC is rate-limited; use Alchemy/QuickNode for production.
# A second Guardian Safe on Robinhood is planned, pending Safe protocol
# support on the network. Until then the kill-switch listens on Base only.
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_CHAIN_ID=4663

# --- Etherscan/Basescan API key (optional, increases rate limits) ---
# Get from: https://etherscan.io/myapikey (works for Basescan too)
ETHERSCAN_API_KEY=

# --- Immutable Core hash (set after first run) ---
# Run: sha256sum governance/prompts/immutable_core.md
# Paste hash here. Entity halts if file hash mismatches.
IMMUTABLE_CORE_HASH=

# --- Operating mode ---
# Options: production | shadow | dev
ENTITY_MODE=shadow
